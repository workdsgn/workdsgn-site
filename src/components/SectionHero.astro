---
---
<section class="section section-hero">
  <div class="section-content">
    <div class="hero-inner">
      <div class="hero-copy">
        <h1 class="hero-h1">For organizations building what doesn't exist yet.</h1>
        <p class="hero-body" data-scramble>WORK is the design and operating partner for founders and executive teams turning ambitious ideas into working reality.</p>
      </div>
    </div>
  </div>
</section>

<style is:global>
  .section-hero {
    position: relative;
    /* dvh accounts for iOS Safari URL bar collapse. `height: auto` (not fixed)
       so the section never exceeds the visible area — see the CTA fix. */
    min-height: 100vh;
    min-height: 100dvh;
    height: auto;
    color: var(--fg);
  }

  .section-hero > .section-content {
    position: relative;
    z-index: 2;
    min-height: 100vh;
    min-height: 100dvh;
    padding: clamp(120px, 15vh, 200px) var(--gutter) clamp(80px, 12vh, 160px);
    display: grid;
    align-items: center;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: clamp(16px, 2vw, 32px);
    width: 100%;
    max-width: var(--maxw);
    margin: 0 auto;
  }

  .hero-copy {
    grid-column: 7 / -1;
    max-width: 540px;
  }

  .hero-h1 {
    font-family: var(--font-display);
    /* Cofo Sans Light — variable axis 300. */
    font-weight: 300;
    /* 64px at desktop cap; clamps down to ~40px on 375px viewport so the
       hero H1 doesn't consume the entire mobile screen. Preferred vw
       target reaches 64px at ~1067px viewport width. */
    font-size: clamp(40px, 6vw, 64px);
    line-height: 1.08;
    letter-spacing: -0.02em;
    text-wrap: balance;
    color: var(--color-cream);
    margin-bottom: clamp(24px, 3vw, 40px);
  }

  .hero-body {
    margin-top: clamp(20px, 3vh, 40px);
    max-width: 460px;
    font-family: var(--font-mono);
    font-weight: 400;
    /* 21px desktop → 14px mobile. Mono line-height stays a bit tighter on
       mobile since narrower measure means shorter lines feel less airy. */
    font-size: clamp(14px, 1.8vw, 21px);
    line-height: 1.7;
    letter-spacing: -0.02em;
    color: var(--color-cream);
  }

  /* 1440+ desktop: widen the hero column so "For organizations" fits on the
     first line. At 72px display, that phrase measures ~640px — bump the
     copy well past that so wrapping stays natural. */
  @media (min-width: 1440px) {
    .hero-copy {
      grid-column: 6 / -1;
      max-width: 780px;
    }
    .hero-body {
      max-width: 620px;
    }
  }

  @media (max-width: 900px) {
    .hero-copy { grid-column: 1 / -1; }
  }
</style>
