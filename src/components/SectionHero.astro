---
import AnimatedText from './AnimatedText.astro';
---
<section class="section section-hero">
  <div class="section-content">
    <div class="hero-inner">
      <div class="hero-copy">
        <AnimatedText as="h1" variant="heading" class="hero-h1">
          For organizations building what doesn't exist yet.
        </AnimatedText>
        <AnimatedText as="p" variant="body" class="hero-body" delay={600}>
          WORK is the design and operating partner for founders and executive
          teams turning ambitious ideas into working reality.
        </AnimatedText>
      </div>
    </div>
  </div>
</section>

<style is:global>
  .section-hero {
    position: relative;
    min-height: 100vh;
    color: var(--fg);
  }

  .section-hero > .section-content {
    position: relative;
    z-index: 2;
    min-height: 100vh;
    padding: clamp(120px, 15vh, 200px) var(--gutter) clamp(80px, 12vh, 160px);
    display: grid;
    align-items: center;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: clamp(16px, 2vw, 32px);
    width: 100%;
    max-width: var(--maxw);
    margin: 0 auto;
  }

  .hero-copy {
    grid-column: 7 / -1;
    max-width: 540px;
  }

  .hero-h1 {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(30px, 3.2vw, 52px);
    line-height: 1.06;
    letter-spacing: -0.02em;
    text-wrap: balance;
  }

  .hero-body {
    margin-top: clamp(24px, 3vh, 40px);
    max-width: 460px;
    font-family: var(--font-body);
    font-size: clamp(14px, 0.95vw, 16px);
    line-height: 1.5;
    color: color-mix(in oklab, var(--fg) 78%, transparent);
  }

  @media (max-width: 900px) {
    .hero-copy { grid-column: 1 / -1; }
  }
</style>
