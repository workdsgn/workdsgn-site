---
const services = [
  {
    n: '01',
    name: 'Strategy & Positioning',
    desc: 'Clarity on where the organization is going and how it will get there.'
  },
  {
    n: '02',
    name: 'Systems & Identity',
    desc: 'Brand, product, and operational systems designed to scale with the business.'
  },
  {
    n: '03',
    name: 'Creative Direction',
    desc: 'Design leadership across campaigns, product, and content with a consistent point of view.'
  },
  {
    n: '04',
    name: 'Operating Design',
    desc: 'Processes, tools, and team structures that make growth possible.'
  },
  {
    n: '05',
    name: 'Presentation & Communication',
    desc: 'Materials built to communicate ideas and win the room.'
  },
  {
    n: '06',
    name: 'Advisory',
    desc: 'Ongoing counsel for founders and leadership teams navigating complexity.'
  }
];
---
<section class="section section-services">
  <div class="section-content">
    <div class="services-inner">
      <p class="services-label" data-scramble>SERVICES</p>
      <ol class="services-list">
        {services.map((s, i) => (
          <li class="service-row fade-in" style={`transition-delay: ${i * 80}ms`}>
            <span class="idx">{s.n}</span>
            <h3 class="name" data-scramble>{s.name}</h3>
            <p class="desc" data-scramble>{s.desc}</p>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>

<style is:global>
  .section-services {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    height: auto;
    color: var(--fg);
  }

  .section-services > .section-content {
    position: relative;
    z-index: 2;
    min-height: 100vh;
    min-height: 100dvh;
    /* Extra breathing room between the last service row and the CTA copy —
       the two sections read as separate movements, not a continuous list. */
    padding: clamp(120px, 15vh, 200px) var(--gutter) clamp(240px, 32vh, 400px);
  }

  .services-inner {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: clamp(16px, 2vw, 32px);
    max-width: var(--maxw);
    margin: 0 auto;
  }

  .services-label {
    grid-column: 3 / span 3;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.18em;
    color: var(--fg);
    opacity: 0.85;
    margin: 0 0 clamp(24px, 3vh, 40px) 0;
  }

  .services-list {
    grid-column: 1 / -1;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .services-list .service-row {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: clamp(16px, 2vw, 32px);
    /* Horizontal padding on the row itself so the hover fill spans edge-to-edge
       of the section-content, not just wraps the text. Vertical padding bumped
       so title + desc read as centered inside a comfortable block, not stacked
       tight against the row border. */
    padding: clamp(28px, 3.4vh, 44px) clamp(16px, 2vw, 32px);
    margin: 0 calc(-1 * clamp(16px, 2vw, 32px));
    border-top: 1px solid color-mix(in oklab, var(--fg) 22%, transparent);
    /* Vertical-center all three cells (idx, name, desc) so multi-line
       descriptions still align to the visual center of the row rather than
       hanging off the title's baseline. */
    align-items: center;
    cursor: pointer;
    color: var(--fg);
    background: transparent;
    /* Bumped specificity over .fade-in (single class) so its opacity/transform
       transition doesn't override our background/color transition on the same
       element. */
    transition:
      background 300ms ease,
      color 300ms ease,
      opacity 800ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 800ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .services-list .service-row:last-child {
    border-bottom: 1px solid color-mix(in oklab, var(--fg) 22%, transparent);
  }

  /* Hover: row fills ink; every descendant inherits so the text reads as
     cream-bg cut into the dark fill (negative-space effect). */
  .services-list .service-row:hover {
    background: var(--color-ink);
    color: var(--color-cream-bg);
  }
  .services-list .service-row:hover * { color: inherit; }

  .idx {
    grid-column: 3 / span 1;
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.08em;
    opacity: 0.7;
  }

  .name {
    grid-column: 4 / span 4;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(18px, 1.5vw, 24px);
    line-height: 1.15;
    letter-spacing: -0.005em;
    margin: 0;
  }

  .desc {
    grid-column: 8 / span 5;
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: 15px;
    line-height: 1.6;
    letter-spacing: -0.01em;
    color: color-mix(in oklab, var(--fg) 78%, transparent);
    margin: 0;
    max-width: 420px;
  }

  @media (max-width: 900px) {
    .services-label,
    .idx { grid-column: 1 / span 2; }
    .name { grid-column: 3 / span 5; }
    .desc { grid-column: 8 / span 5; }
  }
</style>
