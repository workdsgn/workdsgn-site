---
const services = [
  {
    n: '01',
    name: 'Strategy & Positioning',
    desc: 'Clarity on where the organization is going and how it will get there.'
  },
  {
    n: '02',
    name: 'Systems & Identity',
    desc: 'Brand, product, and operational systems designed to scale with the business.'
  },
  {
    n: '03',
    name: 'Creative Direction',
    desc: 'Design leadership across campaigns, product, and content with a consistent point of view.'
  },
  {
    n: '04',
    name: 'Operating Design',
    desc: 'Processes, tools, and team structures that make growth possible.'
  },
  {
    n: '05',
    name: 'Presentation & Communication',
    desc: 'Materials built to communicate ideas and win the room.'
  },
  {
    n: '06',
    name: 'Advisory',
    desc: 'Ongoing counsel for founders and leadership teams navigating complexity.'
  }
];
---
<section class="section section-services">
  <div class="section-content">
    <div class="services-inner">
      <p class="services-label">SERVICES</p>
      <ol class="services-list">
        {services.map((s, i) => (
          <li class="service-row fade-in" style={`transition-delay: ${i * 80}ms`}>
            <span class="idx">{s.n}</span>
            <h3 class="name">{s.name}</h3>
            <p class="desc">{s.desc}</p>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>

<style is:global>
  .section-services {
    position: relative;
    min-height: 100vh;
    min-height: 100svh;
    color: var(--fg);
  }

  .section-services > .section-content {
    position: relative;
    z-index: 2;
    min-height: 100vh;
    min-height: 100svh;
    padding: clamp(120px, 15vh, 200px) var(--gutter) clamp(80px, 12vh, 160px);
  }

  .services-inner {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: clamp(16px, 2vw, 32px);
    max-width: var(--maxw);
    margin: 0 auto;
  }

  .services-label {
    grid-column: 3 / span 3;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.18em;
    color: var(--fg);
    opacity: 0.85;
    margin: 0 0 clamp(24px, 3vh, 40px) 0;
  }

  .services-list {
    grid-column: 1 / -1;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .service-row {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: clamp(16px, 2vw, 32px);
    padding: clamp(22px, 2.6vh, 34px) 0;
    border-top: 1px solid color-mix(in oklab, var(--fg) 22%, transparent);
    align-items: baseline;
  }
  .service-row:last-child {
    border-bottom: 1px solid color-mix(in oklab, var(--fg) 22%, transparent);
  }

  .idx {
    grid-column: 3 / span 1;
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.08em;
    opacity: 0.7;
    align-self: baseline;
  }

  .name {
    grid-column: 4 / span 4;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(18px, 1.5vw, 24px);
    line-height: 1.15;
    letter-spacing: -0.005em;
    margin: 0;
  }

  .desc {
    grid-column: 8 / span 5;
    font-family: var(--font-body);
    font-size: clamp(13px, 0.9vw, 15px);
    line-height: 1.5;
    color: color-mix(in oklab, var(--fg) 78%, transparent);
    margin: 0;
    max-width: 420px;
  }

  @media (max-width: 900px) {
    .services-label,
    .idx { grid-column: 1 / span 2; }
    .name { grid-column: 3 / span 5; }
    .desc { grid-column: 8 / span 5; }
  }
</style>
